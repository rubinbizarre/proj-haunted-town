// Inherit the parent event
event_inherited();

// assign normal & haunted sprites for this world object
sprite_normal = spr_so_phone;
sprite_haunted = spr_so_phone_haunted;

name_str = "Creepy Telephone";
note_str_credit = "Herr-herr! I definitely heard a SPOOKY voice coming through the phone! Maybe it belongs to a dead person who used to live here long ago, nerr.";
note_str_discredit = "Nerr, I was convinced that phone was being used by a Spirit to communicate with us from beyond the grave. But all I could hear was dial tone.";